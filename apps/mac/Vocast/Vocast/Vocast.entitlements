<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	Not sandboxed: Vocast runs a local Python engine (sidecar) and reads user files
	directly, which App Sandbox forbids. This is a directly distributed, notarized
	local tool (not App Store), where a non-sandboxed hardened-runtime app is standard.
	Microphone access still requires this entitlement under the hardened runtime.
	-->
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<!--
	The bundled Python engine (mlx / torch native extensions) is third-party code
	loaded at runtime. Under the hardened runtime (notarized build) it needs these
	to load its own dylibs and use JIT / executable memory.
	-->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
</dict>
</plist>
